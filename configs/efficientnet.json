{
    "experiment_name": "efficientnet_b0_v1",
    "seed": 42,
    "data": {
        "metadata_path": "data/metadata.csv",
        "trainval_fraction": 1.0
    },
    "preprocessing": {
        "img_size": 224
    },
    "model": {
        "model_type": "efficientnet",
        "dropout_rate": 0.3,
        "pretrained": true,
        "kernel_size": 3
    },
    "training": {
        "num_epochs": 15,
        "batch_size": 32,
        "use_weighted_sampler": true,
        "unfreeze_epoch": 4,
        "early_stopping": {
            "enabled": true,
            "patience": 5
        },
        "optimizer": {
            "type": "adamw",
            "lr": 0.0001,
            "weight_decay": 0.001,
            "pos_weight": 1.0
        },
        "scheduler": {
            "type": "cosine",
            "T_max": 15
        }
    }
}