{
  "experiment_name": "vae_perceptual_loss_v10_data_augmentation",

  "seed": 42,

  "data": {
        "metadata_path": "face_crop_final/full_face_crop_metadata.csv",
        "trainval_fraction": 1.0,
        "train_source": ["wiki"]
    },

  "preprocessing": {
    "img_size": 128,
    "type": "vae"
  },

  "model": {
    "name": "vae128_v2",
    "latent_dim": 256,
    "feature_maps": 64,
    "img_channels": 3
  },

  "training": {
    "num_epochs": 70,
    "batch_size": 32,
    "num_workers": 2,

    "lr": 0.00005,
    "weight_decay": 0.0,

    "pixel_weight": 5.0,
    "perceptual_layers": ["relu1_1","relu1_2", "relu2_1", "relu3_1"],

    "kl_annealing": {
      "enabled": true,
      "type": "linear",
      "start_beta": 0.0,
      "end_beta": 0.3,
      "warmup_epochs": 20
    },

    "scheduler": {
      "type": "cosine",
      "T_max": 150
    },

    "early_stopping": {
      "enabled": false, 
      "patience": 20
    },

    "save_dir": "outputs/vae_perceptual_loss_v10_data_augmentation",
    "checkpoint_dir": "checkpoints",

    "sample_every": 5,
    "num_generated_samples": 16,
    "num_reconstruction_images": 8
  }
}