{
    "experiment_name": "baseline_cnn_v1",
    "seed": 42,
    "data": {
        "metadata_path": "data/metadata.csv",
        "number_samples_per_class": 2000,
        "train_size": 0.7,
        "val_size": 0.15
    },
    "preprocessing": {
        "img_size": 224,
        "type": "classifier"
    },
    "model": {
        "model_type": "baseline_cnn",
        "kernel_size": 3,
        "stride": 1,
        "padding": null,
        "channels": [32, 64, 128],
        "hidden_dim": 256,
        "dropout_rate": 0.2
    },
    "training": {
        "num_epochs": 20,
        "batch_size": 32,
        "use_weighted_sampler": false,
        "optimizer": {
            "type": "adamw",
            "lr": 1e-3,
            "weight_decay": 1e-4,
            "pos_weight": 1.0
        },
        "early_stopping": { 
            "enabled": true, 
            "patience": 5 
        },
        "scheduler": { 
            "type": "cosine", 
            "T_max": 20 
        }
    }
}