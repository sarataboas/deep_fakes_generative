{
    "experiment_name": "baseline_cnn_initial",
    "seed": 42,
    "data": {
        "number_samples_per_class": 1000,
        "train_size": 0.7,
        "val_size": 0.15,
        "metadata_path": "data/metadata.csv"
    },
    "preprocessing": {
        "img_size": 224
    },
    "model": {
        "model_type": "baseline",
        "dropout_rate": 0.2,
        "kernel_size": 3
    },
    "training": {
        "optimizer_type": "adamw",
        "lr": 1e-3,
        "weight_decay": 1e-4,
        "num_epochs": 20,
        "batch_size": 32,
        "use_weighted_sampler": false,
        "pos_weight": 1.0,
        "unfreeze_epoch": 0,
        "early_stopping": {
            "enabled": true,
            "patience": 5
        },
        "scheduler": {
            "type": "cosine",
            "T_max": 10
        }
    }
}