{
    "experiment_name": "baseline_cnn_metrics_updated",
    "seed": 42,
    "data": {
        "metadata_path": "data/metadata.csv",
        "trainval_fraction": 0.5
    },
    "preprocessing": {
        "img_size": 224,
        "type": "classifier"
    },
    "model": {
        "model_type": "baseline_cnn",
        "dropout_rate": 0.0,
        "kernel_size": 3,
        "channels": [32, 64, 128],
        "hidden_dim": 256
    },
    "training": {
        "num_epochs": 30,
        "batch_size": 32,
        "use_weighted_sampler": false,
        "optimizer": {
            "type": "adamw",
            "lr": 1e-3,
            "weight_decay": 1e-4,
            "pos_weight": 1.0
        },
        "early_stopping": { 
            "enabled": false
        },
        "scheduler": { 
            "type": "none"
        }
    }
}