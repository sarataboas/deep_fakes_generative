{
  "experiment_name": "vae_perceptual_loss",

  "seed": 42,

  "data": {
    "metadata_path": "face_crop_final/face_crop_metadata.csv",
    "train_source": ["inpainting", "insight", "text2img"]
  },

  "preprocessing": {
    "img_size": 64,
    "type": "vae"
  },

  "model": {
    "name": "vae64",
    "latent_dim": 256,
    "feature_maps": 64,
    "img_channels": 3
  },

  "training": {
    "num_epochs": 100,
    "batch_size": 64,
    "num_workers": 2,

    "lr": 0.00005,
    "weight_decay": 0.0,

    "pixel_weight": 5.0,
    "perceptual_layer_cutoff": 9,

    "kl_annealing": {
      "enabled": true,
      "type": "linear",
      "start_beta": 0.0,
      "end_beta": 0.05,
      "warmup_epochs": 70
    },

    "scheduler": {
      "type": "cosine",
      "T_max": 150
    },

    "early_stopping": {
      "enabled": true, 
      "patience": 20
    },

    "save_dir": "outputs/vae_perceptual_loss",
    "checkpoint_dir": "checkpoints",

    "sample_every": 5,
    "num_generated_samples": 16,
    "num_reconstruction_images": 8
  }
}