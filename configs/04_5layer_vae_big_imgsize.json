{
  "experiment_name": "5_layer_vae_big_imgsize",
  "seed": 42,

  "data": {
    "metadata_path": "data/metadata.csv",
    "train_source": ["wiki"]
  },

  "preprocessing": {
    "img_size": 128,
    "type": "vae"
  },

  "model": {
    "latent_dim": 256,
    "feature_maps": 32,
    "img_channels": 3,
    "architecture": "5_layers"
  },

  "training": {
    "num_epochs": 100,
    "batch_size": 64,
    "num_workers": 2,

    "lr": 0.0002,
    "weight_decay": 0.0,

    "kl_annealing": {
      "enabled": true,
      "type": "linear",
      "start_beta": 0.0,
      "end_beta": 2.0,
      "warmup_epochs": 20
    },

    "scheduler": {
      "type": "cosine",
      "T_max": 100
    },

    "early_stopping": {
      "enabled": false,
      "patience": 10
    },

    "save_dir": "outputs/5_layer_vae_big_imgsize",
    "checkpoint_dir": "checkpoints",

    "sample_every": 5,
    "num_generated_samples": 16,
    "num_reconstruction_images": 8
  }
}