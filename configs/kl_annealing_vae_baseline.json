{
  "experiment_name": "vae_kl_annealing",
  "seed": 42,

  "data": {
    "metadata_path": "data/metadata.csv",
    "train_source": ["inpainting", "insight", "text2img"]
  },

  "preprocessing": {
    "img_size": 64,
    "type": "vae"
  },

  "model": {
    "latent_dim": 128,
    "feature_maps": 32,
    "img_channels": 3
  },

  "training": {
    "num_epochs": 150,
    "batch_size": 64,
    "num_workers": 2,

    "lr": 0.0002,
    "weight_decay": 0.0,

    "beta": 1.0,

    "kl_annealing": {
      "enabled": true,
      "type": "linear",
      "start_beta": 0.0,
      "end_beta": 4.0,
      "warmup_epochs": 70
    },

    "scheduler": {
      "type": "cosine",
      "T_max": 100
    },

    "early_stopping": {
      "enabled": false,
      "patience": 15
    },

    "save_dir": "outputs/vae_kl_annealing_150epochs_2e-4_lr",
    "checkpoint_dir": "checkpoints",

    "sample_every": 5,
    "num_generated_samples": 16,
    "num_reconstruction_images": 8
  }
}