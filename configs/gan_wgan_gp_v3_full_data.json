{
  "experiment_name": "gan_wgan_gp_v3_full_data",
  "seed": 42,

  "data": {
    "metadata_path": "face_crop_final/full_face_crop_metadata.csv",
    "train_source": ["wiki"]
  },

  "preprocessing": {
    "img_size": 64,
    "type": "vae"
  },

  "model": {
    "latent_dim": 256,
    "feature_maps": 64,
    "img_channels": 3,
    "spectral_norm": false
  },

  "training": {
    "num_epochs": 100,
    "batch_size": 64,
    "num_workers": 4,

    "lr_g": 0.0001,
    "lr_c": 0.0001,
    "beta1": 0.0,
    "beta2": 0.9,

    "n_critic": 5,
    "lambda_gp": 10.0,
    "grad_clip": 0.0,

    "save_dir": "outputs/gan_wgan_gp_v3_full_data",
    "checkpoint_dir": "checkpoints",

    "sample_every": 5
  }
}
